<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Use a NestedScrollView so the header scrolls with the content instead of being hidden programmatically -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/podcast_detail_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Podcast Header -->
            <LinearLayout
                android:id="@+id/podcast_detail_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="?attr/colorSurfaceContainer"
                android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/podcast_detail_image"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:scaleType="centerCrop"
                android:contentDescription="Podcast artwork"
                android:clickable="true"
                android:focusable="true" />

                <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">
                <TextView
                    android:id="@+id/podcast_detail_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/podcast_detail_description"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:gravity="top"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/podcast_detail_show_more"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show more"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:paddingEnd="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/subscribe_button"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Subscribe"
                android:backgroundTint="@android:color/transparent"
                android:textColor="?attr/colorPrimary" />

            <ImageButton
                android:id="@+id/share_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:src="@drawable/ic_share"
                android:contentDescription="Share podcast"
                android:tint="?attr/colorOnSurface"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:id="@+id/notification_bell_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:src="@drawable/ic_notifications"
                android:contentDescription="Toggle notifications"
                android:visibility="gone"
                android:tint="?attr/colorOnSurface"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>
    </LinearLayout>

            <!-- Episodes RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/episodes_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:scrollbars="vertical"
                android:paddingBottom="96dp"
                android:clipToPadding="false"
                android:background="?attr/colorSurface" />

            <!-- Loading Indicator -->
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/loading_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                app:trackThickness="4dp"
                app:indicatorColor="?attr/colorPrimary" />

            <!-- Empty State -->
            <TextView
                android:id="@+id/empty_state_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="No episodes found"
                android:gravity="center"
                android:visibility="gone" />
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Contextual selection toolbar shown when episodes are long-pressed -->
    <LinearLayout
        android:id="@+id/episode_selection_toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:visibility="gone"
        android:background="?attr/colorSurfaceContainer"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <ImageButton
            android:id="@+id/episode_selection_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_clear"
            android:contentDescription="Clear selection"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/colorOnSurface" />

        <Button
            android:id="@+id/action_episode_toggle_played"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="Mark as played"
            android:textColor="?attr/colorOnSurface"
            android:textAllCaps="true" />

        <Button
            android:id="@+id/action_episode_toggle_download"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="Download"
            android:textColor="?attr/colorOnSurface"
            android:textAllCaps="true" />

    </LinearLayout>

    <!-- Floating action button to return to top when the user starts scrolling -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        style="@style/Widget.MaterialComponents.FloatingActionButton"
        android:id="@+id/scroll_to_top_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Scroll to top"
        app:srcCompat="@drawable/ic_arrow_up"
        android:visibility="gone"
        app:fabSize="normal"
        app:useCompatPadding="false"
        app:backgroundTint="?attr/colorPrimary"
        app:rippleColor="?attr/colorOnPrimary"
        android:tint="?attr/colorOnPrimary"
        android:layout_gravity="bottom|end"
        android:elevation="8dp" />

</FrameLayout>
