<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Simple title bar that floats above the scrollable content -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/podcasts_title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceContainer"
        app:title="Podcasts"
        app:titleTextColor="?attr/colorOnSurface"
        app:menu="@menu/podcasts_title_menu"
        android:elevation="4dp" />

    <!-- Content area where the header can scroll away with the list -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/podcasts_coordinator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:background="?attr/colorSurfaceContainer">

            <com.google.android.material.appbar.AppBarLayout
                android:id="@+id/podcasts_header_appbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorSurfaceContainer"
                app:elevation="0dp">

                <LinearLayout
                    android:id="@+id/podcasts_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_scrollFlags="scroll|enterAlways">

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/podcasts_sort_tabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorSurfaceContainer"
                app:tabMode="scrollable"
                app:tabTextColor="?attr/colorOnSurface"
                app:tabSelectedTextColor="?attr/colorPrimary"
                app:tabIndicatorColor="?attr/colorPrimary"
                app:tabIndicatorFullWidth="false">

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Popular" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last Updated" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New Podcasts" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Genre" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A-Z" />

            </com.google.android.material.tabs.TabLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/genre_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorSurface"
                android:visibility="gone"
                android:nestedScrollingEnabled="false"
                android:scrollbars="vertical" />

            <!-- Search App Bar (Material 3 style) -->
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/podcasts_search_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:background="?attr/colorSurfaceContainer"
                app:contentInsetStart="0dp"
                app:contentInsetEnd="0dp"
                app:contentInsetStartWithNavigation="0dp"
                android:paddingTop="8dp">

                <!-- Use a custom end-icon so visibility can be controlled independently of focus/IME -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/search_podcast_text_input"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    app:boxStrokeColor="?attr/colorOutline"
                    app:boxBackgroundColor="?attr/colorSurface"
                    app:hintEnabled="false"
                    app:startIconDrawable="@drawable/ic_search"
                    app:endIconMode="custom"
                    app:endIconDrawable="@drawable/ic_shuffle"
                    app:endIconContentDescription="@string/shuffle_podcast_desc">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/search_podcast_edittext"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:imeOptions="actionSearch"
                        android:textColor="?attr/colorOnSurface"
                        android:textColorHint="?attr/colorOnSurfaceVariant"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:paddingStart="64dp"
                        android:background="@null"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:hint="Search podcasts..." />
                </com.google.android.material.textfield.TextInputLayout>

                <ImageButton
                    android:id="@+id/podcasts_shuffle_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_shuffle"
                    android:contentDescription="@string/shuffle_podcast_desc"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="?attr/colorOnSurface" />

                <ImageButton
                    android:id="@+id/podcasts_filter_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_filter_list"
                    android:contentDescription="Filter podcasts"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="?attr/colorOnSurface" />
            </com.google.android.material.appbar.MaterialToolbar>

            <!-- Filters container (hidden by default; toggled by the filter button) -->
            <LinearLayout
                android:id="@+id/filters_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="?attr/colorSurfaceContainer"
                android:paddingTop="2dp"
                android:paddingBottom="8dp">

                <!-- Genre Filter (Exposed dropdown - Material 3) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/genre_filter_layout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="2dp"
                    app:boxStrokeColor="?attr/colorOutline"
                    app:endIconMode="dropdown_menu"
                    app:hintEnabled="true"
                    android:hint="Genre"
                    app:boxBackgroundColor="?attr/colorSurface">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/genre_filter_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="?attr/colorOnSurface"
                        android:padding="8dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Sort Filter (Exposed dropdown - Material 3) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/sort_filter_layout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="6dp"
                    app:boxStrokeColor="?attr/colorOutline"
                    app:endIconMode="dropdown_menu"
                    app:hintEnabled="true"
                    android:hint="Sort"
                    app:boxBackgroundColor="?attr/colorSurface">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/sort_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="?attr/colorOnSurface"
                        android:padding="8dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Reset + Save Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginVertical="6dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/reset_filters_button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Reset Filters" />

                    <Button
                        android:id="@+id/save_search_button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Save Search"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

                </LinearLayout>

            <!-- Search context sort bar: visible only when showing search results (replaces the browse header) -->
            <LinearLayout
                android:id="@+id/search_sort_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="?attr/colorSurfaceContainer"
                android:paddingHorizontal="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/search_sort_filter_layout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxStrokeColor="?attr/colorOutline"
                    app:endIconMode="dropdown_menu"
                    app:hintEnabled="true"
                    android:hint="Sort"
                    app:boxBackgroundColor="?attr/colorSurface">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/search_sort_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="?attr/colorOnSurface"
                        android:padding="8dp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            </com.google.android.material.appbar.AppBarLayout>

            <!-- Podcasts RecyclerView (primary scroller) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/podcasts_recycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:nestedScrollingEnabled="true"
                android:scrollbars="vertical"
                android:paddingBottom="96dp"
                android:clipToPadding="false"
                android:background="?attr/colorSurface"
                app:layout_behavior="@string/appbar_scrolling_view_behavior" />

            <!-- Loading Feedback Container (overlays content area, below tabs) -->
            <LinearLayout
                android:id="@+id/loading_feedback_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/colorSurfaceContainer"
                android:visibility="gone"
                app:layout_behavior="@string/appbar_scrolling_view_behavior">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/loading_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:trackThickness="4dp"
                    app:indicatorColor="?attr/colorPrimary" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/loading_horizontal_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="32dp"
                    android:layout_marginBottom="12dp"
                    android:max="100"
                    android:progress="0"
                    app:trackThickness="4dp"
                    app:trackCornerRadius="2dp"
                    app:trackStopIndicatorSize="0dp"
                    app:indicatorColor="?attr/colorPrimary"
                    app:trackColor="?attr/colorSurfaceVariant" />

                <TextView
                    android:id="@+id/loading_message_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingHorizontal="32dp"
                    android:lineSpacingExtra="4dp"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnSurface" />

            </LinearLayout>

            <!-- Empty State (overlays content area, below tabs) -->
            <TextView
                android:id="@+id/empty_state_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="No podcasts found"
                android:gravity="center"
                android:paddingHorizontal="32dp"
                android:lineSpacingExtra="4dp"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                android:background="?attr/colorSurfaceContainer"
                android:visibility="gone"
                app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <LinearLayout
        android:id="@+id/search_results_loading_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="88dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingTop="10dp"
        android:paddingEnd="14dp"
        android:paddingBottom="10dp"
        android:background="?attr/colorSurfaceContainerHigh"
        android:elevation="6dp"
        android:visibility="gone">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/search_results_loading_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            app:trackThickness="3dp"
            app:indicatorSize="24dp"
            app:indicatorColor="?attr/colorPrimary" />

        <TextView
            android:id="@+id/search_results_loading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/loading_more_search_results"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Floating action button to return to top and appear while scrolling -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        style="@style/Widget.MaterialComponents.FloatingActionButton"
        android:id="@+id/scroll_to_top_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Scroll to top"
        app:srcCompat="@drawable/ic_arrow_up"
        android:visibility="gone"
        app:fabSize="normal"
        app:useCompatPadding="false"
        app:backgroundTint="?attr/colorPrimary"
        app:rippleColor="?attr/colorOnPrimary"
        android:tint="?attr/colorOnPrimary"
        android:layout_gravity="bottom|end"
        android:elevation="8dp" />

</FrameLayout>
