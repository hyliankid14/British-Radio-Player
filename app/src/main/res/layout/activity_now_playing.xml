<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurfaceContainer">

    <!-- Top App Bar (Material 3) -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/top_app_bar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurfaceContainer"
        app:titleTextColor="?attr/colorOnSurface"
        app:navigationIconTint="?attr/colorOnSurface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="4dp" />

    <!-- Station Artwork (Square) -->
    <com.hyliankid14.bbcradioplayer.SquareImageView
        android:id="@+id/now_playing_artwork"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:contentDescription="Station artwork"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/top_app_bar"
        app:layout_constraintBottom_toTopOf="@id/playback_controls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_max="@dimen/now_playing_artwork_width"
        app:layout_constraintHeight_max="@dimen/now_playing_artwork_width"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.3"
        android:layout_marginBottom="32dp" />

    <!-- Manual mark-as-played button (only visible for podcast episodes) -->
    <ImageButton
        android:id="@+id/now_playing_mark_played"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:backgroundTint="?attr/colorSurface"
        android:src="@drawable/ic_check"
        android:tint="?attr/colorOnSurface"
        android:contentDescription="Mark episode as played"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp" />

    <!-- Show Name -->
    <TextView
        android:id="@+id/now_playing_show_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Radio"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="8dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/now_playing_artwork"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Next Show Info -->
    <TextView
        android:id="@+id/now_playing_next_show"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="3dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/now_playing_show_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Episode Title / show subtitle (reduced size so it's smaller than show name but larger than artist/song) -->
    <TextView
        android:id="@+id/now_playing_episode_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"
        android:textSize="16sp"
        android:lineHeight="22sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="4dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/now_playing_next_show"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Episode release date (podcasts only) -->
    <TextView
        android:id="@+id/now_playing_release_date"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/now_playing_episode_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Episode Description / Artist/Track Info with Show More link -->
    <LinearLayout
        android:id="@+id/now_playing_description_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="0dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/now_playing_release_date"
        app:layout_constraintBottom_toTopOf="@id/podcast_progress_group"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/now_playing_artist_track"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:maxLines="4"
            android:ellipsize="end"
            android:visibility="gone" />

        <TextView
            android:id="@+id/now_playing_show_more"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show more"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/md_theme_primary"
            android:gravity="center"
            android:visibility="gone"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />
    </LinearLayout>

    <!-- Open Podcast Button (shown when current show maps to a podcast) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/now_playing_open_podcast"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="8dp"
        android:text="Open Podcast"
        android:textAllCaps="false"
        android:visibility="gone"
        android:contentDescription="Open podcast detail"
        app:layout_constraintTop_toBottomOf="@id/now_playing_description_container"
        app:layout_constraintBottom_toTopOf="@id/playback_controls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Podcast progress time labels (only visible for podcasts) -->
    <LinearLayout
        android:id="@+id/podcast_progress_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/playback_seekbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/playback_elapsed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:text="0:00" />

        <TextView
            android:id="@+id/playback_remaining"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:text="-0:00"
            android:layout_gravity="end"
            android:layout_weight="1"
            android:gravity="end" />
    </LinearLayout>

    <!-- Scrubber (only visible for podcasts, positioned directly above playback controls) -->
    <com.google.android.material.slider.Slider
        android:id="@+id/playback_seekbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:valueFrom="0.0"
        android:valueTo="1.0"
        app:trackHeight="3dp"
        app:thumbRadius="8dp"
        app:layout_constraintBottom_toTopOf="@id/playback_controls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Playback Controls -->
    <LinearLayout
        android:id="@+id/playback_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

            <!-- Stop Icon Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/now_playing_stop"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                style="@style/Widget.Material3.Button.IconButton"
                app:icon="@drawable/ic_stop"
                app:iconTint="?attr/colorOnSurface"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:contentDescription="Stop" />

            <!-- Previous Icon Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/now_playing_previous"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                style="@style/Widget.Material3.Button.IconButton"
                app:icon="@drawable/ic_skip_previous"
                app:iconTint="?attr/colorOnSurface"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:contentDescription="Previous" />

            <!-- Play/Pause Filled Button (High Emphasis) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/now_playing_play_pause"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_margin="4dp"
                style="@style/Widget.Material3.Button.IconButton.Filled"
                app:icon="@drawable/ic_play_arrow"
                app:iconTint="@null"
                app:iconSize="32dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:contentDescription="Play/Pause" />

            <!-- Next Icon Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/now_playing_next"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                style="@style/Widget.Material3.Button.IconButton"
                app:icon="@drawable/ic_skip_next"
                app:iconTint="?attr/colorOnSurface"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:contentDescription="Next" />

            <!-- Favorite Icon Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/now_playing_favorite"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                style="@style/Widget.Material3.Button.IconButton"
                app:icon="@drawable/ic_star_outline"
                app:iconTint="@null"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:padding="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:contentDescription="Add to Favorites" />



    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
