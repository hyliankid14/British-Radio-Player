<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurfaceContainer"
        app:titleTextColor="?attr/colorOnSurface"
        app:navigationIconTint="?attr/colorOnSurface"
        android:elevation="4dp" />

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <CheckBox
                android:id="@+id/exclude_non_english_checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/exclude_non_english_label" />

        </LinearLayout>

        <TextView
            android:id="@+id/index_source"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Source: Google Cloud index"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/index_last_rebuilt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Last updated: —"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/index_podcast_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="— podcasts indexed"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/index_episode_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="— episodes indexed"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1" />

    </LinearLayout>

</ScrollView>

</LinearLayout>
