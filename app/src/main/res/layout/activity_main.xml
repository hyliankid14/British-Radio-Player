<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurfaceContainer">

    <!-- Top App Bar (Material 3) -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/top_app_bar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurfaceContainer"
        app:titleTextColor="?attr/colorOnSurface"
        app:navigationIconTint="?attr/colorOnSurface"
        app:menu="@menu/top_app_bar_menu"
        android:elevation="4dp" />

    <!-- Fill the small gap under the app bar with the same surface colour -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="?attr/colorSurfaceContainer" />

    <!-- Favorites toggle group shown under the app bar for quick access -->
    <LinearLayout
        android:id="@+id/favorites_toggle_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/transparent"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fav_tab_stations"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="2dp"
            android:text="Stations"
            app:icon="@drawable/ic_star"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:cornerRadius="100dp"
            android:importantForAccessibility="yes"
            android:focusable="true" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fav_tab_subscribed"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text="Subscribed"
            app:icon="@drawable/ic_podcast"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:cornerRadius="100dp"
            android:importantForAccessibility="yes"
            android:focusable="true" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fav_tab_saved"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text="Saved"
            app:icon="@drawable/ic_bookmark"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:cornerRadius="100dp"
            android:importantForAccessibility="yes"
            android:focusable="true" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fav_tab_searches"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text="Searches"
            app:icon="@drawable/ic_search"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:cornerRadius="100dp"
            android:importantForAccessibility="yes"
            android:focusable="true" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fav_tab_history"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="0dp"
            android:text="History"
            app:icon="@drawable/ic_history"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:cornerRadius="100dp"
            android:importantForAccessibility="yes"
            android:focusable="true" />

    </LinearLayout>

    <!-- Dynamic Fragment Container (Podcasts) -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <!-- Static Content Container (Stations &amp; Settings) -->
    <FrameLayout
        android:id="@+id/static_content_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/stations_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="?attr/colorSurfaceContainer">

            <!-- Filter Buttons (static; won't move during swipes) -->
            <include
                layout="@layout/filter_buttons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:id="@+id/filter_buttons_include" />

            <!-- Stations content (this is translated during swipes; tabs above remain static) -->
            <LinearLayout
                android:id="@+id/stations_content"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/vpn_warning_banner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSecondaryContainer"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/vpn_warning_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="@string/vpn_station_warning"
                        android:textColor="?attr/colorOnSecondaryContainer"
                        android:textSize="14sp" />

                    <ImageButton
                        android:id="@+id/vpn_warning_dismiss"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="8dp"
                        android:src="@drawable/ic_clear"
                        android:contentDescription="@string/vpn_warning_dismiss_description"
                        app:tint="?attr/colorOnSecondaryContainer" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/stations_list"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:clipToPadding="false"
                    android:scrollbars="vertical"
                    android:background="?attr/colorSurface" />

                <TextView
                    android:id="@+id/favorite_stations_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No favourite stations yet"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="?attr/colorSurface"
                    android:visibility="gone" />

                <!-- Recent Songs list (shown when "Songs" tab is selected) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recent_songs_list"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:scrollbars="vertical"
                    android:background="?attr/colorSurface"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/recent_songs_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No recently played songs yet.\nSongs detected while a station is playing will appear here."
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="?attr/colorSurface"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Favorites toggle group moved to top under the app bar -->

            <!-- Stations (favourited radio stations) - reuse existing stations list -->
            <!-- (stations_list already exists above and is used as the Stations view) -->

            <!-- Subscribed podcasts: keep the card look but remove the old collapsible header -->
            <FrameLayout
                android:id="@+id/favorites_podcasts_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="0dp"
                android:visibility="gone"
                android:background="?attr/colorSurface"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/favorites_podcasts_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:paddingTop="0dp"
                    android:clipToPadding="true"
                    android:scrollbars="vertical"
                    android:background="?attr/colorSurface" />

                <TextView
                    android:id="@+id/favorites_podcasts_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No subscribed podcasts yet"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="?attr/colorSurface"
                    android:visibility="gone" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/favorites_podcasts_loading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:padding="16dp"
                    android:visibility="gone"
                    app:trackThickness="4dp"
                    app:indicatorColor="?attr/colorPrimary" />
            </FrameLayout>

            <!-- Saved Episodes: remove collapsible header and show as its own card when selected -->
            <LinearLayout
                android:id="@+id/saved_episodes_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                android:background="?attr/colorSurface"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:orientation="vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/saved_episodes_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:paddingTop="0dp"
                    android:clipToPadding="true"
                    android:scrollbars="vertical"
                    android:background="?attr/colorSurface" />

                <TextView
                    android:id="@+id/saved_episodes_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No saved episodes yet"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="?attr/colorSurface"
                    android:visibility="gone" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/saved_searches_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                android:background="?attr/colorSurface"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/saved_searches_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:text="Saved Searches"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/saved_searches_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No saved searches yet"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center"
                    android:padding="16dp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/saved_searches_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:clipToPadding="true"
                    android:scrollbars="vertical"
                    android:background="?attr/colorSurface" />
            </LinearLayout>

            <!-- History: full-width list (no background card) -->
            <FrameLayout
                android:id="@+id/favorites_history_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                android:background="?attr/colorSurface"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/favorites_history_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:paddingTop="0dp"
                    android:clipToPadding="true"
                    android:scrollbars="vertical"
                    android:background="?attr/colorSurface" />

                <TextView
                    android:id="@+id/favorites_history_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No history yet"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="?attr/colorSurface"
                    android:visibility="gone" />

            </FrameLayout>


        </LinearLayout>

        <!-- Settings View -->
        <include
            android:id="@+id/settings_container"
            layout="@layout/settings_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </FrameLayout>

    <include
        layout="@layout/mini_player"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_navigation_menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        style="@style/Widget.Material3.BottomNavigationView" />

</LinearLayout>
