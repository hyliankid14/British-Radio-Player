#pragma once

/*
 * Copy this file to config.h and fill in your credentials.
 * config.h is listed in .gitignore and must never be committed.
 *
 * For Wokwi simulation leave the Wokwi-GUEST values as-is –
 * Wokwi routes all WiFi traffic through its own gateway regardless.
 */

/* WiFi ------------------------------------------------------------------- */
#define WIFI_SSID     "Wokwi-GUEST"
#define WIFI_PASSWORD ""

/* GCS API (BBC Radio Player podcast index) ------------------------------- */
#define GCS_BUCKET   "bbc-radio-player-index-20260317-bc149e38"
#define GCS_BASE_URL "https://storage.googleapis.com/" GCS_BUCKET

/* BBC OPML feed ---------------------------------------------------------- */
/* The original bbc.co.uk URL redirects to this HTTP endpoint. */
#define BBC_OPML_URL "http://podcasts.files.bbci.co.uk/podcasts.opml"

/* TF card mount point ---------------------------------------------------- */
#define SD_MOUNT_POINT "/sdcard"
